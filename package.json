{
  "name": "loneprocess-frontend",
  "version": "1.5.0",
  "description": "Löneportalen - Digital checklista för löneprocessen baserad på POL LA 2025.2",
  "main": "src/loneportalen.html",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "lint": "eslint src --ext .js,.html",
    "lint:fix": "eslint src --ext .js,.html --fix",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,html,css}\"",
    "validate": "npm run lint && npm run format:check",
    "lighthouse": "lhci autorun"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlgerhardsson/loneprocess-frontend.git"
  },
  "keywords": [
    "löneportal",
    "POL",
    "löneprocess",
    "checklista",
    "payroll",
    "HR"
  ],
  "author": "Carl Gerhardsson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carlgerhardsson/loneprocess-frontend/issues"
  },
  "homepage": "https://github.com/carlgerhardsson/loneprocess-frontend#readme",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@lhci/cli": "^0.15.1",
    "eslint": "^8.55.0",
    "eslint-plugin-html": "^7.1.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
