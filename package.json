{
  "name": "loneprocess-frontend",
  "version": "1.5.0",
  "description": "Löneportalen - Digital checklista för löneprocessen baserad på POL LA 2025.2",
  "main": "src/loneportalen.html",
  "scripts": {
    "dev": "npx serve src",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/**/*.html --ext .html",
    "lint:fix": "eslint src/**/*.html --ext .html --fix",
    "format": "prettier --write \"src/**/*.{html,css,js}\"",
    "format:check": "prettier --check \"src/**/*.{html,css,js}\"",
    "validate": "npm run lint && npm run format:check && npm run test",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlgerhardsson/loneprocess-frontend.git"
  },
  "keywords": [
    "löneprocess",
    "POL",
    "checklista",
    "löneadministration"
  ],
  "author": "Carl Gerhardsson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carlgerhardsson/loneprocess-frontend/issues"
  },
  "homepage": "https://github.com/carlgerhardsson/loneprocess-frontend#readme",
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-html": "^8.0.0",
    "husky": "^9.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.1",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.{html,css,js}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
