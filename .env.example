# Löneprocess API Configuration
# 
# VIKTIGT: Kopiera denna fil till .env och lägg in din riktiga API-nyckel
# .env är redan i .gitignore och kommer ALDRIG commit:as till git
#
# Steg:
# 1. Kopiera: cp .env.example .env
# 2. Öppna .env och ersätt placehodern med din riktiga API-nyckel
# 3. Använd ALDRIG din riktiga nyckel i denna fil!

# API Base URL (produktion)
VITE_API_BASE_URL=https://loneprocess-api-922770673146.us-central1.run.app

# API Key (ersätt med din riktiga nyckel i .env filen)
VITE_LONEPROCESS_API_KEY=your-api-key-here-DO-NOT-COMMIT-REAL-KEY
